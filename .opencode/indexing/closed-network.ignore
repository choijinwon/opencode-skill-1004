# OpenCode closed-network indexing ignore template
#
# Keep source files visible, but exclude generated folders, dependency caches,
# wheel files, MLflow runs, and large model artifacts that slow file-tree scans.

.opencode/
.opencode/node_modules/
.venv/
venv/
env/
ENV/
__pycache__/
*.py[cod]
.DS_Store
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

node_modules/
dist/
build/
.cache/

*.whl
*.tar.gz
*.zip

mlruns/
mlartifacts/
mlflow.db
ai_studio/tracking/
